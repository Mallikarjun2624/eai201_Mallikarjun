def find_path(algo):
    start = start_var.get()
    end = end_var.get()
    if not start or not end:
        messagebox.showwarning("Input Error", "Please select both start and destination.")
        return
    if start == end:
        messagebox.showinfo("Result", "You are already at the destination.")
        return

    if algo == "BFS":
        path, dist = bfs(start, end)
    elif algo == "DFS":
        path, dist = dfs(start, end)
    elif algo == "UCS":
        path, dist = ucs(start, end)
    else:
        path, dist = a_star(start, end)

    if path:
        out = f"{algo}: {' → '.join(path)} | Distance: {dist} meters"
    else:
        out = f"{algo}: No path found"
    output_box.insert(tk.END, out + "\n")
    output_box.see(tk.END)

def search_staff():
    dept = staff_var.get()
    if not dept:
        messagebox.showwarning("Input Error", "Please select a department/area.")
        return
    info = contacts.get(dept, None)
    output_box.insert(tk.END, f"--- {dept} Contacts ---\n")
    if isinstance(info, dict):
        for key, value in info.items():
            if isinstance(value, list):
                for person in value:
                    output_box.insert(tk.END, f"{key}: {person['name']} - {person['phone']}\n")
            elif isinstance(value, dict):
                output_box.insert(tk.END, f"{key}: {value['name']} - {value['phone']}\n")
            else:
                output_box.insert(tk.END, f"{key}: {value}\n")
    elif isinstance(info, list):
        for person in info:
            output_box.insert(tk.END, f"{person['name']} - {person['phone']}\n")
    else:
        output_box.insert(tk.END, "No contacts found.\n")
    output_box.insert(tk.END, "\n")
    output_box.see(tk.END)

def open_map():
    html = """
    <!DOCTYPE html>
    <html>
    <head>
        <title>Chanakya University Map</title>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
        <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    </head>
    <body style="margin:0;">
        <div id="map" style="width: 100%; height: 100vh;"></div>
        <script>
            var map = L.map('map').setView([13.1976, 77.7066], 16);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19
            }).addTo(map);
            // Add a basic marker for Chanakya University
            L.marker([13.1976, 77.7066]).addTo(map)
                .bindPopup("<b>Chanakya University</b><br>Devanahalli").openPopup();
        </script>
    </body>
    </html>
    """
    filename = "chanakya_map.html"
    with open(filename, "w", encoding="utf-8") as f:
        f.write(html)
    webbrowser.open(filename)

