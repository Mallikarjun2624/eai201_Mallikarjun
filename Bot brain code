# ----------------------------
# PATHFINDING ALGORITHMS
# ----------------------------
def bfs(start, goal):
    queue = deque([(start, [start], 0)])
    visited = set()
    while queue:
        node, path, dist = queue.popleft()
        if node == goal:
            return path, dist
        if node not in visited:
            visited.add(node)
            for nbr, d in distances.get(node, {}).items():
                if nbr not in visited:
                    queue.append((nbr, path + [nbr], dist + d))
    return None, None

def dfs(start, goal):
    stack = [(start, [start], 0)]
    visited = set()
    while stack:
        node, path, dist = stack.pop()
        if node == goal:
            return path, dist
        if node not in visited:
            visited.add(node)
            for nbr, d in distances.get(node, {}).items():
                if nbr not in visited:
                    stack.append((nbr, path + [nbr], dist + d))
    return None, None

def ucs(start, goal):
    queue = [(0, start, [start])]
    visited = set()
    while queue:
        cost, node, path = heapq.heappop(queue)
        if node == goal:
            return path, cost
        if node not in visited:
            visited.add(node)
            for nbr, d in distances.get(node, {}).items():
                if nbr not in visited:
                    heapq.heappush(queue, (cost + d, nbr, path + [nbr]))
    return None, None

def heuristic(a, b):
    return 0

def a_star(start, goal):
    queue = [(0, 0, start, [start])]
    visited = set()
    while queue:
        est, cost, node, path = heapq.heappop(queue)
        if node == goal:
            return path, cost
        if node not in visited:
            visited.add(node)
            for nbr, d in distances.get(node, {}).items():
                if nbr not in visited:
                    new_cost = cost + d
                    est_total = new_cost + heuristic(nbr, goal)
                    heapq.heappush(queue, (est_total, new_cost, nbr, path + [nbr]))
    return None, None

