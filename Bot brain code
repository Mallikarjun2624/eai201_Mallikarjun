def chatbot_lookup(user_text):
    text = user_text.lower()
    # exact keyword contains check
    for keys, resp in chatbot_knowledge.items():
        for key in keys:
            if key in text:
                return resp
    # fallback: try to answer simple distance question "how far from X to Y"
    if "how far" in text or "distance" in text:
        # try to parse "from <A> to <B>" or "between <A> and <B>"
        words = text.replace("?", "").split()
        if "from" in words and "to" in words:
            try:
                i = words.index("from")
                a = words[i+1]
                j = words.index("to")
                b = words[j+1]
                # try to match keys loosely by capitalizing and matching start
                a_match = next((k for k in distances.keys() if k.lower().startswith(a)), None)
                b_match = next((k for k in distances.keys() if k.lower().startswith(b)), None)
                if a_match and b_match and b_match in distances.get(a_match, {}):
                    return f"Distance from {a_match} to {b_match} is {distances[a_match][b_match]} meters."
            except Exception:
                pass
    return "Sorry, I don't know that yet. Try asking about library, VC, hostel, medical, sports, admission, or 'map'."

